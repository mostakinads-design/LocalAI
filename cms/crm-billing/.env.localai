# mostakinads-design/crm-laravel — LocalAI environment template
#
# Usage:
#   cp cms/crm-billing/.env.localai cms/crm-billing/.env
#
# Then start the full stack:
#   docker compose -f docker-compose.cms.yaml \
#     --profile crm-billing --profile with-localai up -d

APP_NAME="Liberu CRM (LocalAI)"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8093

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=crm-billing-mysql
DB_PORT=3306
DB_DATABASE=crm_billing
DB_USERNAME=crm
DB_PASSWORD=crm_secret

# ── Queue ───────────────────────────────────────────────────────────────────
# Invoice auto-generation jobs run asynchronously via the database queue.
QUEUE_CONNECTION=database

# ── AI / OpenAI-compatible ──────────────────────────────────────────────────
# Point to the crm-billing-bridge, which converts deal/contact data into
# structured invoice JSON via LocalAI and records each job as a tracked task.
# View generated invoices at http://localhost:8013/tasks
OPENAI_API_KEY=localai
OPENAI_BASE_URL=http://crm-billing-bridge:8013/v1

# The bridge also exposes a dedicated invoice endpoint that CRM queue workers
# can call directly (no OpenAI SDK needed):
#   POST http://crm-billing-bridge:8013/invoices/generate
#   Body: {"customer_name":"...", "deal_title":"...", "deal_value":1000, "currency":"USD", ...}

# ── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@localai.local
MAIL_FROM_NAME="${APP_NAME}"

# ── Cache / Session ─────────────────────────────────────────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:8093
SESSION_DOMAIN=localhost
