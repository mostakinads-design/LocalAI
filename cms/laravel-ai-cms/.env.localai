# laravel-ai-cms — LocalAI environment template
#
# Usage:
#   cp cms/laravel-ai-cms/.env.localai cms/laravel-ai-cms/.env
#
# Then start the full stack:
#   docker compose -f docker-compose.cms.yaml \
#     --profile laravel-ai-cms --profile with-localai up -d

APP_NAME="LocalAI CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8091

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=laravel-ai-cms-mysql
DB_PORT=3306
DB_DATABASE=laravel_ai_cms
DB_USERNAME=cms
DB_PASSWORD=cms_secret

# ── Queue ───────────────────────────────────────────────────────────────────
# The slug / summary generation jobs run asynchronously via the database queue.
QUEUE_CONNECTION=database

# ── AI / OpenAI-compatible ──────────────────────────────────────────────────
# Point to the laravel-ai-cms-bridge, which proxies to LocalAI and records
# each generation as a tracked task (visible at http://localhost:8012/tasks).
OPENAI_API_KEY=localai
OPENAI_BASE_URL=http://laravel-ai-cms-bridge:8012/v1

# To call LocalAI directly (without task visibility), use:
# OPENAI_BASE_URL=http://api:8080/v1

# ── Cache / Session ─────────────────────────────────────────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
